{
  "name": "code-fail-sounds",
  "displayName": "Code Fail Sounds",
  "description": "Play hilarious sound effects when your code fails - choose from multiple sounds",
  "version": "1.1.0",
  "publisher": "Madhav1111",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Madhav703/code-fail-sounds"
  },
  "bugs": {
    "url": "https://github.com/Madhav703/code-fail-sounds/issues"
  },
  "keywords": [
    "sound",
    "audio",
    "error",
    "fun",
    "notification"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Code Fail Sounds",
      "properties": {
        "multiSoundEffect.selectedSound": {
          "type": "string",
          "default": "faah",
          "enum": [
            "faah",
            "meoww",
            "abe-sale",
            "modi"
          ],
          "enumDescriptions": [
            "Faah sound effect",
            "Meoww sound effect",
            "Abe Sale sound effect",
            "Modi sound effect"
          ],
          "description": "Select which sound to play on errors"
        },
        "multiSoundEffect.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable sound effects"
        }
      }
    },
    "commands": [
      {
        "command": "multiSoundEffect.selectSound",
        "title": "Multi Sound: Select Sound"
      },
      {
        "command": "multiSoundEffect.toggle",
        "title": "Multi Sound: Toggle On/Off"
      },
      {
        "command": "multiSoundEffect.testSound",
        "title": "Multi Sound: Test Sound"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.93.0",
    "typescript": "^5.0.0"
  }
}
